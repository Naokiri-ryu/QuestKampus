<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#151515">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:title="Jurnal Misi"
            app:titleTextColor="#FFD700" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp">

            <ImageView
                android:id="@+id/iv_bg_wood"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:src="@drawable/menu_message_bg0"
                android:scaleType="fitXY"
                app:layout_constraintTop_toTopOf="@id/content_container"
                app:layout_constraintBottom_toBottomOf="@id/content_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <ImageView
                android:id="@+id/iv_bg_paper"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="12dp"
                android:src="@drawable/menu_message_bg1"
                android:scaleType="fitXY"
                app:layout_constraintTop_toTopOf="@id/content_container"
                app:layout_constraintBottom_toBottomOf="@id/content_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <LinearLayout
                android:id="@+id/content_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="38dp"
                android:paddingTop="44dp"
                android:paddingBottom="44dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_detail_rank"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_rank_s"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:text="RANK S"
                        android:textColor="#000000"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tv_detail_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AKTIF"
                        android:textColor="#8B0000"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_detail_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:textColor="#3E2723"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_detail_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="#5D4037"
                    android:textSize="11sp"
                    android:text="Deskripsi misi tertera di sini..."
                    android:lineSpacingExtra="5dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="18dp"
                    android:background="#333E2723" />

                <TextView
                    android:id="@+id/tv_detail_deadline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📅 Deadline: -"
                    android:textSize="10sp"
                    android:textColor="#B71C1C"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_detail_reward"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="💎 Reward: -"
                    android:textSize="10sp"
                    android:textColor="#0D47A1"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_view_support"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="20dp"
                    android:text="Buka Lampiran Soal"
                    android:textColor="#3E2723"
                    android:textSize="9sp"
                    app:strokeColor="#3E2723" />

                <TextView
                    android:id="@+id/label_proof"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="BUKTI PENYELESAIAN"
                    android:textColor="#3E2723"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cv_proof_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="#0D000000"
                    app:cardCornerRadius="6dp"
                    app:strokeColor="#3E2723"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/iv_proof_preview"
                            android:layout_width="match_parent"
                            android:layout_height="160dp"
                            android:scaleType="centerInside"
                            android:visibility="gone" />
                        <Button
                            android:id="@+id/btn_view_proof_link"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Lihat Link Bukti"
                            android:textColor="#0D47A1"
                            android:textSize="9sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/layout_actions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_assigned_to"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:gravity="center"
                        android:text="Misi ini sedang dikerjakan"
                        android:textColor="#B71C1C"
                        android:textSize="9sp"
                        android:visibility="gone" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_take_quest"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="AMBIL MISI"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:visibility="gone"
                        app:backgroundTint="#42A5F5"
                        app:cornerRadius="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_complete_quest"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="SERAHKAN QUEST"
                        android:textColor="#1A1A1A"
                        android:textSize="11sp"
                        app:backgroundTint="#FFD700"
                        app:cornerRadius="6dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_status_footer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:text="QUEST SELESAI"
                    android:textColor="#2E7D32"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_edit_quest"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        app:backgroundTint="#FFD700"
        app:srcCompat="@android:drawable/ic_menu_edit"
        app:tint="#1A1A1A" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>