<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rpg_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/rpg_background">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:title="Quest Journal"
            app:titleTextColor="@color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Card Utama -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/rpg_card_surface"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/accent_gold"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_detail_rank"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_rank_s"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:text="RANK S"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tv_detail_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AKTIF"
                            android:textColor="@color/accent_gold"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="Judul Quest"
                        app:hintTextColor="@color/accent_gold"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_detail_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="Deskripsi"
                        app:hintTextColor="@color/accent_gold"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_detail_desc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:inputType="textMultiLine" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="#33FFFFFF" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_detail_deadline"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="📅 Deadline: -"
                            android:textColor="@color/accent_gold" />
                        <Button
                            android:id="@+id/btn_edit_deadline"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ubah Deadline"
                            android:textSize="12sp"
                            android:textColor="@color/accent_gold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_detail_reward"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="💰 Reward: -"
                        android:textColor="@color/exp_blue" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- File Pendukung -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="LAMPIRAN SOAL"
                android:textColor="@color/text_secondary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_view_support"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Buka Lampiran"
                android:textColor="@color/white"
                app:strokeColor="@color/accent_gold" />

            <!-- Bukti Penyelesaian -->
            <TextView
                android:id="@+id/label_proof"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="BUKTI PENYELESAIAN"
                android:textColor="@color/text_secondary"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cv_proof_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#1AFFFFFF"
                app:cardCornerRadius="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/iv_proof_preview"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:scaleType="centerInside"
                        android:visibility="gone" />
                    <Button
                        android:id="@+id/btn_view_proof_link"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Lihat Link Bukti"
                        android:visibility="gone"
                        android:textColor="@color/accent_gold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons -->
            <!-- Action Buttons -->
            <LinearLayout
                android:id="@+id/layout_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="vertical">

                <!-- Label Status Pekerja (Untuk Misi Kelompok) -->
                <TextView
                    android:id="@+id/tv_assigned_to"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Misi ini sedang kamu kerjakan"
                    android:textColor="@color/accent_gold"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone" />

                <!-- Tombol Ambil Misi Kelompok -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_take_quest"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="12dp"
                    android:text="AMBIL MISI INI"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:backgroundTint="@color/exp_blue"
                    app:cornerRadius="12dp" />

                <!-- Tombol Simpan Perubahan (Hanya untuk tugas pribadi) -->
                <Button
                    android:id="@+id/btn_save_quest"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="SIMPAN PERUBAHAN"
                    android:backgroundTint="#2C3E50"
                    android:textColor="@color/white"
                    app:cornerRadius="12dp" />

                <!-- Tombol Serahkan Hasil (Upload Bukti) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_complete_quest"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:text="SERAHKAN QUEST"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    app:backgroundTint="@color/accent_gold"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_status_footer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:text="QUEST SELESAI"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/loading_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>