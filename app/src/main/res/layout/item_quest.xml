<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="5dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/common_grid_bg"
        android:paddingTop="20dp"
        android:paddingBottom="28dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <TextView
            android:id="@+id/tv_quest_rank"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_rank_c"
            android:gravity="center"
            android:text="C"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_quest_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Judul Quest"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tv_quest_rank"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_quest_flavor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="🌿 Misi Pencarian"
            android:textColor="#DDDDDD"
            android:textSize="11sp"
            app:layout_constraintEnd_toEndOf="@id/tv_quest_title"
            app:layout_constraintStart_toStartOf="@id/tv_quest_title"
            app:layout_constraintTop_toBottomOf="@id/tv_quest_title" />

        <TextView
            android:id="@+id/tv_quest_deadline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="📅 Deadline: -"
            android:textColor="#FFD700"
            android:textSize="11sp"
            app:layout_constraintEnd_toEndOf="@id/tv_quest_title"
            app:layout_constraintStart_toStartOf="@id/tv_quest_title"
            app:layout_constraintTop_toBottomOf="@id/tv_quest_flavor" />

        <TextView
            android:id="@+id/tv_status_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:text="AKTIF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@id/tv_quest_title"
            app:layout_constraintTop_toBottomOf="@id/tv_quest_deadline" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>