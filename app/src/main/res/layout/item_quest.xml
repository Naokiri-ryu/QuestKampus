<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/rpg_card_surface"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:strokeColor="@color/accent_gold"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Rank Badge (oval, colored by rank) -->
        <TextView
            android:id="@+id/tv_quest_rank"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_rank_badge"
            android:gravity="center"
            android:text="S"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="A" />

        <!-- Quest Title -->
        <TextView
            android:id="@+id/tv_quest_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:text="Judul Quest"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/cb_quest_done"
            app:layout_constraintStart_toEndOf="@id/tv_quest_rank"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Mengerjakan Tugas Besar PBO" />

        <!-- Deadline text -->
        <TextView
            android:id="@+id/tv_quest_deadline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="📅 Deadline: -"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="@id/tv_quest_title"
            app:layout_constraintStart_toStartOf="@id/tv_quest_title"
            app:layout_constraintTop_toBottomOf="@id/tv_quest_title"
            tools:text="📅 20 Des 2025, 23:59 · Sisa 2 hari" />

        <!-- Complete Checkbox -->
        <CheckBox
            android:id="@+id/cb_quest_done"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/accent_gold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
