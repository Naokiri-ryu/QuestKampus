<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rpg_background">

    <!-- App Bar / Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/rpg_background">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Guild &amp; Kelompok"
            app:titleTextColor="@color/accent_gold"
            app:navigationIcon="@android:drawable/ic_menu_revert" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Pesan jika belum punya kelompok -->
        <TextView
            android:id="@+id/tv_empty_party"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kamu belum bergabung dengan kelompok manapun.\n\nTekan tombol di bawah untuk Memulai!"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Daftar Kelompok -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_parties"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="100dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Tombol Mengambang (Floating Action Buttons) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:gravity="end">

        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fab_join_party"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="GABUNG PIN"
            app:icon="@android:drawable/ic_menu_search"
            android:textColor="@color/white"
            app:backgroundTint="@color/exp_blue" />

        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fab_create_party"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BUAT KELOMPOK"
            app:icon="@android:drawable/ic_input_add"
            android:textColor="@color/black"
            app:backgroundTint="@color/accent_gold" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>