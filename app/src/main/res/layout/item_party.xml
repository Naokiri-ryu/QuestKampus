<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/common_btn_choice"
        android:orientation="vertical"
        android:paddingVertical="20dp"
        android:paddingHorizontal="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <!-- TEKS DIJADIKAN HITAM (#1A1A1A) -->
            <TextView
                android:id="@+id/tv_item_party_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nama Kelompok"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_item_party_member_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👥 0"
                android:textColor="#3E2723"
                android:textStyle="bold"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_item_party_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Deskripsi kelompok..."
            android:textColor="#5D4037"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="11sp" />

        <ProgressBar
            android:id="@+id/pb_item_party_hp"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="12dp"
            android:progressTint="@color/hp_red"
            android:max="500"
            android:progress="500" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>