<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinator_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rpg_background"
    tools:context=".ui.activities.MainActivity">

    <!-- ============================================================
         MAIN CONTENT (everything above BottomNav)
         ============================================================ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="56dp">

        <!-- === PROFILE STRIP === -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cv_profile"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/rpg_card_surface"
            app:cardCornerRadius="30dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeColor="@color/accent_gold"
            app:strokeWidth="2dp">
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_player_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="4dp"
            android:text="Adventurer"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/btn_party"
            app:layout_constraintStart_toEndOf="@id/cv_profile"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_player_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚔ Level 1"
            android:textColor="@color/accent_gold"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tv_player_name"
            app:layout_constraintTop_toBottomOf="@id/tv_player_name" />

        <TextView
            android:id="@+id/tv_player_gold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="🪙 0"
            android:textColor="@color/gold_coin"
            android:textSize="12sp"
            app:layout_constraintBaseline_toBaselineOf="@id/tv_player_level"
            app:layout_constraintStart_toEndOf="@id/tv_player_level" />

        <ImageButton
            android:id="@+id/btn_party"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Party"
            android:src="@android:drawable/ic_menu_share"
            app:layout_constraintEnd_toStartOf="@id/btn_logout"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/accent_gold" />

        <ImageButton
            android:id="@+id/btn_logout"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Logout"
            android:src="@android:drawable/ic_lock_power_off"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/hp_red" />

        <!-- === HP BAR === -->
        <TextView
            android:id="@+id/label_hp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="10dp"
            android:text="HP"
            android:textColor="@color/hp_red"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cv_profile" />

        <ProgressBar
            android:id="@+id/pb_hp"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="12dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="16dp"
            android:progress="100"
            android:progressTint="@color/hp_red"
            app:layout_constraintBottom_toBottomOf="@id/label_hp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/label_hp"
            app:layout_constraintTop_toTopOf="@id/label_hp" />

        <!-- === EXP BAR === -->
        <TextView
            android:id="@+id/label_exp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="EXP"
            android:textColor="@color/exp_blue"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/label_hp"
            app:layout_constraintTop_toBottomOf="@id/label_hp" />

        <ProgressBar
            android:id="@+id/pb_exp"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="12dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="16dp"
            android:progress="0"
            android:progressTint="@color/exp_blue"
            app:layout_constraintBottom_toBottomOf="@id/label_exp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/label_exp"
            app:layout_constraintTop_toTopOf="@id/label_exp" />

        <!-- Divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:background="@color/rpg_card_surface"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/pb_exp" />

        <!-- ============================================================
             CONTENT FRAME — switches between Dashboard / Quest Board
             ============================================================ -->
        <FrameLayout
            android:id="@+id/content_frame"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider">

            <!-- ===== PANEL 1: DASHBOARD ===== -->
            <ScrollView
                android:id="@+id/panel_dashboard"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="📊 RINGKASAN QUEST"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <!-- Stat cards row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <!-- Active -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            app:cardBackgroundColor="@color/rpg_card_surface"
                            app:cardCornerRadius="10dp"
                            app:strokeColor="@color/accent_gold"
                            app:strokeWidth="1dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp">
                                <TextView
                                    android:id="@+id/tv_count_active"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/accent_gold"
                                    android:textSize="28sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Aktif"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Completed -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="6dp"
                            app:cardBackgroundColor="@color/rpg_card_surface"
                            app:cardCornerRadius="10dp"
                            app:strokeColor="#4CAF50"
                            app:strokeWidth="1dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp">
                                <TextView
                                    android:id="@+id/tv_count_done"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="#4CAF50"
                                    android:textSize="28sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Selesai"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Failed -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            app:cardBackgroundColor="@color/rpg_card_surface"
                            app:cardCornerRadius="10dp"
                            app:strokeColor="@color/hp_red"
                            app:strokeWidth="1dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp">
                                <TextView
                                    android:id="@+id/tv_count_failed"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/hp_red"
                                    android:textSize="28sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Gagal"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- Motivation / Tips card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cv_tip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardBackgroundColor="@color/rpg_card_surface"
                        app:cardCornerRadius="10dp"
                        app:strokeColor="@color/exp_blue"
                        app:strokeWidth="1dp">
                        <TextView
                            android:id="@+id/tv_tip"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="14dp"
                            android:text="⚔ Tip: Selesaikan quest Rank S untuk EXP dan Gold terbanyak!"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- No quests hint -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cv_start_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:cardBackgroundColor="@color/rpg_card_surface"
                        app:cardCornerRadius="10dp"
                        app:strokeColor="@color/accent_gold"
                        app:strokeWidth="1dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:padding="20dp"
                            android:text="🗺 Belum ada quest!\nBuka tab Quest Board dan tekan ＋ untuk mulai."
                            android:textColor="@color/accent_gold"
                            android:textSize="14sp" />
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </ScrollView>

            <!-- ===== PANEL 2: QUEST BOARD ===== -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/panel_quests"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <!-- Filter chips -->
                <HorizontalScrollView
                    android:id="@+id/hsv_chips"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingStart="12dp"
                    android:scrollbars="none"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:selectionRequired="true"
                        app:singleLine="true"
                        app:singleSelection="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_all"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="Semua"
                            android:textColor="@color/white" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_active"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Aktif"
                            android:textColor="@color/white" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_done"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selesai"
                            android:textColor="@color/white" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_failed"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gagal"
                            android:textColor="@color/white" />
                    </com.google.android.material.chip.ChipGroup>
                </HorizontalScrollView>

                <!-- Quest count label -->
                <TextView
                    android:id="@+id/tv_quest_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="4dp"
                    android:text="0 quest"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/hsv_chips" />

                <!-- Empty state -->
                <TextView
                    android:id="@+id/tv_empty_quests"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="32dp"
                    android:gravity="center"
                    android:text="Tidak ada quest di sini.\nTekan ＋ untuk menambah quest baru!"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_quest_count" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_quests"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="4dp"
                    android:clipToPadding="false"
                    android:paddingBottom="72dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_quest_count"
                    tools:listitem="@layout/item_quest" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </FrameLayout>

        <!-- Loading indicator (centered over everything) -->
        <ProgressBar
            android:id="@+id/loading_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- FAB (only visible on Quest Board tab) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_add_quest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="72dp"
            android:contentDescription="Tambah quest"
            android:visibility="gone"
            app:backgroundTint="@color/accent_gold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:srcCompat="@android:drawable/ic_input_add"
            app:tint="@color/black" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ============================================================
         BOTTOM NAVIGATION (fixed at bottom via CoordinatorLayout)
         ============================================================ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:background="@color/rpg_card_surface"
        app:itemIconTint="@color/bottom_nav_selector"
        app:itemTextColor="@color/bottom_nav_selector"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
